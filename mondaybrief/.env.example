# Database
DATABASE_URL=postgresql://user:pass@host:5432/mondaybrief

# Chicago Open Data — free app token from https://data.cityofchicago.org/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# Geocodio — free 2500/day from https://www.geocod.io/
GEOCODIO_API_KEY=

# Mapbox — free 100k Matrix calls/mo from https://account.mapbox.com/
MAPBOX_API_KEY=

# Twilio Lookup — free Basic, ~1¢ LTI from https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Resend — https://resend.com/api-keys (re_... key on a verified sending domain)
RESEND_API_KEY=
RESEND_FROM_EMAIL=brief@mondaybrief.app
# Svix signing secret (whsec_...) from the Resend dashboard webhook config
RESEND_WEBHOOK_SECRET=

# CAN-SPAM footer — honest sender name + a REAL physical postal address.
# Required by law in every commercial email; rendered in the brief footer.
COMPANY_NAME=MondayBrief
COMPANY_POSTAL_ADDRESS=

# Inngest — https://www.inngest.com/
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Stripe — https://dashboard.stripe.com/
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
BILLING_PORTAL_URL=

# Langfuse (optional observability) — https://cloud.langfuse.com/
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Auth + feedback signing — generate with: python -c "import secrets;print(secrets.token_urlsafe(32))"
MAGIC_LINK_SECRET=
FEEDBACK_TOKEN_SECRET=

# Ops alerting (pipeline failure emails)
OPERATOR_EMAIL=matthewseyoum17@gmail.com

# Streamlit base URL — used by feedback links inside PDF
APP_BASE_URL=http://localhost:8501
