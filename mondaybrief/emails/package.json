    "@react-email/components": "^0.0.25",
    "@react-email/render": "^1.0.1"
  },
  "devDependencies": {
    "react-email": "^3.0.0",
    "typescript": "^5.5.4"
  },
  "engines": { "node": ">=20" }
}
